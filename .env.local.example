# AEM Content Fragment API Configuration
# Copy this file to .env.local and fill in your AEM instance details

# Base URL of your AEM author instance
# Example: https://author-p12345-e67890.adobeaemcloud.com
AEM_API_BASE_URL=https://author-p12345-e67890.adobeaemcloud.com

# GraphQL endpoint path (relative to AEM_API_BASE_URL)
# Standard path: /content/cq:graphql/default/execute.json
AEM_GRAPHQL_ENDPOINT=/content/cq:graphql/default/execute.json

# Bearer token for authenticated requests to AEM
# Generate this in AEM user settings or IMS console
AEM_ACCESS_TOKEN=your_bearer_token_here

# Optional: Enable debug logging
DEBUG=false
